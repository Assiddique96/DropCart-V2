{
  "name": "dropcart",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.0.6",
    "@prisma/adapter-neon": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@reduxjs/toolkit": "^2.8.2",
    "axios": "^1.13.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "imagekit": "^6.0.0",
    "inngest": "^4.0.0",
    "lucide-react": "^0.525.0",
    "next": "^16.1.7",
    "openai": "^6.33.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-hot-toast": "^2.5.2",
    "react-redux": "^9.2.0",
    "recharts": "^3.1.2",
    "stripe": "^17.7.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.5.0",
    "@types/react": "19.2.14",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "prisma": "^7.7.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "setupFilesAfterFramework": [
      "<rootDir>/jest.setup.js"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1",
      "\\.(css|less|scss|sass)$": "<rootDir>/__tests__/__mocks__/styleMock.js"
    },
    "transform": {
      "^.+\\.(js|jsx|ts|tsx)$": [
        "babel-jest",
        {
          "presets": [
            "next/babel"
          ]
        }
      ]
    },
    "testPathPattern": [
      "__tests__"
    ],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "lib/**/*.{js,ts}",
      "app/api/**/*.{js,ts}",
      "components/**/*.{jsx,tsx}",
      "!**/*.d.ts"
    ]
  }
}
